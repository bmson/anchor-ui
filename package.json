{
  "name": "@anchor-org/anchor-cli",
  "version": "0.0.0",
  "license": "MIT",
  "bin": {
    "anchor-cli": "dist/cli.js"
  },
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "link": "npm run build && npm link",
    "unlink": "npm unlink -g @anchor-org/anchor-cli",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "ink": "^5.2.1",
    "react": "^18.2.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
